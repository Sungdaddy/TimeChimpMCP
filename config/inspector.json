{
  "mcpServers": {
    "timechimp-local": {
      "command": "python",
      "args": ["-m", "timechimp_mcp_server.main"],
      "env": {
        "TIMECHIMP_API_KEY": "your_api_key_here",
        "TIMECHIMP_BASE_URL": "https://v2.api.timechimp.com",
        "LOG_LEVEL": "INFO"
      }
    },
    "timechimp-installed": {
      "command": "timechimp-mcp-server",
      "env": {
        "TIMECHIMP_API_KEY": "your_api_key_here",
        "TIMECHIMP_BASE_URL": "https://v2.api.timechimp.com",
        "LOG_LEVEL": "INFO"
      }
    }
  }
} 